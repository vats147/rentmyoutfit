{
    "name": "shahidra-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "Scalable backend for ShahidRa Rentals",
    "main": "dist/server.js",
    "scripts": {
        "dev": "~/.bun/bin/bun --watch src/server.ts",
        "build": "~/.bun/bin/bun build ./src/server.ts --outdir ./dist --target node",
        "start": "~/.bun/bin/bun run src/server.ts",
        "prisma:generate": "~/.bun/bin/bunx prisma generate --schema=../prisma/schema.prisma",
        "prisma:push": "~/.bun/bin/bunx prisma db push --schema=../prisma/schema.prisma"
    },
    "dependencies": {
        "@prisma/client": "^6.11.1",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.3",
        "socket.io": "^4.8.1",
        "z-ai-web-dev-sdk": "^0.0.16",
        "zod": "^4.0.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.3.0",
        "prisma": "^6.11.1",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3"
    }
}